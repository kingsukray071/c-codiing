#include <stdio.h>

int main() {
    int num, temp, i = 0;
    int a[10];

    printf("Enter number: ");
    scanf("%d", &num);

    // If the number is negative, it's not a palindrome
    if (num < 0) {
        printf("It is not a palindrome\n");
        return 0;
    }

    temp = num;

    // Extract digits of the number
    while (temp) {
        a[i++] = temp % 10;
        temp /= 10;
    }

    // Check if the number is a palindrome
    for (int j = 0; j < i / 2; j++) {
        if (a[j] != a[i - j - 1]) {
            printf("It is not a palindrome\n");
            return 0;
        }
    }

    // If it passes all checks
    printf("It is a palindrome\n");
    
    return 0;  // End of the program
}
